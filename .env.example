# ═══════════════════════════════════════════════════════════════════════
# AI Provider Configuration
# ═══════════════════════════════════════════════════════════════════════

# Active provider: gemini | openai | anthropic (coming soon) | ollama (coming soon)
AI_PROVIDER=gemini

# Gemini (default provider)
# Note: GEMINI_API_KEY is stored client-side in browser localStorage — NOT in .env
# Override model (optional):
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI (alternative provider — Phase 3)
# Note: OPENAI_API_KEY is stored client-side in browser localStorage — NOT in .env
# Override model (optional, default: gpt-4o-mini):
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o

# Anthropic (coming soon — Phase 4)
# ANTHROPIC_API_KEY stored client-side

# Ollama local (coming soon — Phase 5, free/no API key)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════════════
# AWS S3 (optional — for clip backup/gallery)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BUCKET=your-public-bucket-name

# YouTube cookies (optional — paste Netscape-format cookies to bypass bot detection)
# YOUTUBE_COOKIES=...
