# ═══════════════════════════════════════════════════════════════════════
# AI Provider Configuration
# ═══════════════════════════════════════════════════════════════════════

# Active provider: gemini | openai | anthropic | ollama
AI_PROVIDER=gemini

# Gemini (default provider)
# Note: GEMINI_API_KEY is stored client-side in browser localStorage — NOT in .env
# Override model (optional):
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI (alternative provider)
# Note: OPENAI_API_KEY can be stored client-side or set here
# OPENAI_API_KEY=sk-...        (or send X-OpenAI-Key header per request)
# Override model (optional, default: gpt-4o-mini):
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-... (or send X-Anthropic-Key header per request)
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Ollama (local, free — no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════════════
# AWS S3 (optional — for clip backup/gallery)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BUCKET=your-public-bucket-name

# YouTube cookies (optional — paste Netscape-format cookies to bypass bot detection)
# YOUTUBE_COOKIES=...
